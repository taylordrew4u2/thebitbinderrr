<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BAEssentialMaxInstallSize</key>
	<integer>10485760</integer>
	<key>BAInitialDownloadRestrictions</key>
	<dict>
		<key>BADownloadAllowance</key>
		<integer>10485760</integer>
		<key>BADownloadDomainAllowList</key>
		<array>
			<string>github.com</string>
		</array>
		<key>BAEssentialDownloadAllowance</key>
		<integer>5242880</integer>
	</dict>
	<key>BAManifestURL</key>
	<string>https://github.com/taylordrew4u-llc/thebitbinderr/releases/download/latest/manifest.json</string>
	<key>BAMaxInstallSize</key>
	<integer>52428800</integer>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>The-BitBinder.thebitbinder.refresh</string>
		<string>The-BitBinder.thebitbinder.sync</string>
	</array>
	<key>CFBundleDisplayName</key>
	<string>BitBinder</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>10.1</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CloudKitSchemaConfiguration</key>
	<dict>
		<key>PublicKeyAlgorithm</key>
		<string>ECDSA P-256</string>
		<key>PublicKeyIdentifier</key>
		<string>com.bitbinder.cloudkit.schema.publickey</string>
		<key>SchemaVerificationEnabled</key>
		<true/>
		<key>SchemaVersion</key>
		<string>2.3.0</string>
	</dict>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>api.openai.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
			<key>openrouter.ai</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Allow camera access to scan jokes from notebooks and import photos.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Allow saving exported PDFs and recordings locally.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Allow microphone access to record your performances and talk to The BitBuddy AI assistant.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Allow saving processed notebook images back to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Allow photo library access to import images containing jokes.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Allow speech recognition to transcribe recordings and enable Talk-to-Text joke creation.</string>
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.The-BitBinder.thebitbinder</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<true/>
			<key>NSUbiquitousContainerName</key>
			<string>BitBinder</string>
			<key>NSUbiquitousContainerSupportedFolderFormats</key>
			<array>
				<string>public.folder</string>
			</array>
		</dict>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportsDocumentBrowser</key>
	<true/>
</dict>
</plist>
